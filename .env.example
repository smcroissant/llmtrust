# Database — Neon Postgres connection string
# Format: postgresql://user:password@host/db?sslmode=require
DATABASE_URL=

# Better Auth — Secret key for session encryption (min 32 chars)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Better Auth — Base URL of the application
BETTER_AUTH_URL=http://localhost:3000

# API Key prefix for Electron/app authentication
API_KEY_PREFIX=llmt_

# Stripe — Secret key (sk_test_... for dev, sk_live_... for prod)
STRIPE_SECRET_KEY=sk_test_placeholder

# Stripe — Webhook signing secret (whsec_...)
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# Stripe — Publishable key (pk_test_... for dev, pk_live_... for prod)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder

# Stripe — Price IDs (from Stripe Dashboard → Products)
STRIPE_PRICE_PRO=price_pro_placeholder
STRIPE_PRICE_TEAM=price_team_placeholder

# Clerk — Secret key (for legacy/migration auth)
CLERK_SECRET_KEY=

# Clerk — Publishable key
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# UploadThing — Token for file uploads
UPLOADTHING_TOKEN=

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000
API_URL=http://localhost:3000

# ============================================
# Monitoring & Error Tracking (Sentry)
# ============================================
# Get your DSN from https://sentry.io/settings/[org]/projects/[project]/keys/
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ============================================
# Logging
# ============================================
# Log level: debug | info | warn | error
LOG_LEVEL=info

# ============================================
# Email — Resend (https://resend.com)
# ============================================
# Free tier: 100 emails/day
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=

# ============================================
# Vercel Analytics (auto-configured on Vercel)
# ============================================
# VERCEL_ENV — set automatically by Vercel
# VERCEL_GIT_COMMIT_SHA — set automatically by Vercel
