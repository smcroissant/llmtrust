# ============================================
# LLM Trust — Environment Variables
# ============================================
# Copy this file: cp .env.example .env.local
# Then fill in your values below.
#
# ✅ = Required   ⭕ = Optional
# The app will fail fast on startup if required vars are missing.

# ─── Database ✅ ────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# ─── Better Auth ✅ ─────────────────────────────────
BETTER_AUTH_SECRET=your-secret-key-minimum-32-characters
BETTER_AUTH_URL=http://localhost:3000

# ─── Stripe ✅ ──────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_PRICE_PRO=price_xxxxxxxxxxxxx
STRIPE_PRICE_TEAM=price_xxxxxxxxxxxxx

# ─── App URLs ✅ ────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000
API_URL=http://localhost:3000

# ─── API ⭕ ─────────────────────────────────────────
API_KEY_PREFIX=llmt_
CRON_SECRET=

# ─── Telemetry ⭕ ──────────────────────────────────
TELEMETRY_API_KEY=

# ─── Sentry ⭕ ─────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ─── Logging ⭕ ────────────────────────────────────
# Options: debug | info | warn | error
LOG_LEVEL=info

# ─── Email (Resend) ⭕ ─────────────────────────────
RESEND_API_KEY=

# ─── UploadThing ⭕ ────────────────────────────────
UPLOADTHING_TOKEN=

# ─── Legacy Clerk (migration only) ⭕ ──────────────
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# ─── Vercel (auto-configured) ─────────────────────
# VERCEL_ENV
# VERCEL_URL
# VERCEL_GIT_COMMIT_SHA
