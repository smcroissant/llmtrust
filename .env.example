# ============================================
# LLM Trust — Environment Variables
# ============================================
# Copy this file: cp .env.example .env.local
# Then fill in your values below.
#
# ✅ = Required   ⭕ = Optional
# The app will fail fast on startup if required vars are missing.

# ─── Database ✅ ────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# ─── Better Auth ✅ ─────────────────────────────────
BETTER_AUTH_SECRET=your-secret-key-minimum-32-characters
BETTER_AUTH_URL=http://localhost:3000

# ─── Stripe ✅ ──────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_PRICE_PRO=price_xxxxxxxxxxxxx
STRIPE_PRICE_TEAM=price_xxxxxxxxxxxxx

# Stripe — Secret key (sk_test_... for dev, sk_live_... for prod)
STRIPE_SECRET_KEY=sk_test_placeholder

# Stripe — Webhook signing secret (whsec_...)
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# Stripe — Publishable key (pk_test_... for dev, pk_live_... for prod)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder

# Stripe — Price IDs (from Stripe Dashboard → Products)
# See docs/MONETIZATION.md §4.2 for product setup instructions
# Pro: $19/mo, $182/yr (~20% off) | Team: $49/mo, $470/yr (~20% off)
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly_placeholder
STRIPE_PRICE_PRO_ANNUAL=price_pro_annual_placeholder
STRIPE_PRICE_TEAM_MONTHLY=price_team_monthly_placeholder
STRIPE_PRICE_TEAM_ANNUAL=price_team_annual_placeholder

# Clerk — Secret key (for legacy/migration auth)
CLERK_SECRET_KEY=

# Clerk — Publishable key
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# UploadThing — Token for file uploads
UPLOADTHING_TOKEN=

# ─── App URLs ✅ ────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000
API_URL=http://localhost:3000

# ─── API ⭕ ─────────────────────────────────────────
API_KEY_PREFIX=llmt_
CRON_SECRET=

# ─── Telemetry ⭕ ──────────────────────────────────
TELEMETRY_API_KEY=

# ─── Sentry ⭕ ─────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ─── Logging ⭕ ────────────────────────────────────
# Options: debug | info | warn | error
LOG_LEVEL=info

# ─── Email (Resend) ⭕ ─────────────────────────────
RESEND_API_KEY=

# ─── UploadThing ⭕ ────────────────────────────────
UPLOADTHING_TOKEN=

# ─── Legacy Clerk (migration only) ⭕ ──────────────
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# ─── Vercel (auto-configured) ─────────────────────
# VERCEL_ENV
# VERCEL_URL
# VERCEL_GIT_COMMIT_SHA
