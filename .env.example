# Database — Neon Postgres connection string
# Format: postgresql://user:password@host/db?sslmode=require
DATABASE_URL=

# Better Auth — Secret key for session encryption (min 32 chars)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Better Auth — Base URL of the application
BETTER_AUTH_URL=http://localhost:3000

# API Key prefix for Electron/app authentication
API_KEY_PREFIX=llmt_

# Stripe — Secret key (sk_test_... for dev, sk_live_... for prod)
STRIPE_SECRET_KEY=

# Stripe — Webhook signing secret (whsec_...)
SIGNING_SECRET=

# Stripe — Publishable key (pk_test_... for dev, pk_live_... for prod)
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=

# Clerk — Secret key (for legacy/migration auth)
CLERK_SECRET_KEY=

# Clerk — Publishable key
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# UploadThing — Token for file uploads
UPLOADTHING_TOKEN=

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000
API_URL=http://localhost:3000

# Stripe Product ID
PRODUCT_ID=
